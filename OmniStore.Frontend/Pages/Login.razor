@page "/login"
@using System.Net.Http.Json
@using OmniStore.Frontend.Services
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="container mt-5" style="max-width: 400px;">
    <div class="card shadow-sm">
        <div class="card-body">
            <h3 class="text-center mb-4">Admin Login</h3>

            <div class="mb-3">
                <label>Email</label>
                <input @bind="email" class="from-control" placeholder="youremail@xyz.com" />
            </div>
            <div class="mb-3">
                <label>Password</label>
                <input @bind="password" type="password" class="from-control" placeholder="Your password" />
            </div>

            <button @onclick="DoLogin" class="btn btn-dark w-100">Sign In</button>

            @if(!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-3">@errorMessage</div>
            }
            
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";

    private class LoginResponse { public string accessToken { get; set; } = ""; }

    private async Task DoLogin()
    {
        var credentials = new { email = email, password = password };

        var response = await Http.PostAsJsonAsync("/login", credentials);
        if(response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<LoginResponse>();
            if(result != null)
            {
                AuthState.Token = result.accessToken;
                Navigation.NavigateTo("/support");
            }
        }
        else
        {
            errorMessage = "Invalid email or password";
        }
    }
}

